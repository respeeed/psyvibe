---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Tag from '../ui/Tag.astro';
import { imagePath, videoPath } from '../../lib/images';

interface WhyTrustData {
  title?: string | null;
  body?: string | null;
  tags?: string[] | null;
  image?: string | null;
  video?: string | null;
}

interface Props {
  data: WhyTrustData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const body = data?.body ?? null;
const tags = data?.tags ?? [];
const imageSrc = imagePath(data?.image);
const videoSrc = videoPath(data?.video);
const hasMedia = imageSrc ?? videoSrc;

const hasContent = title || body || tags.length > 0 || hasMedia;
if (!hasContent) {
  return null;
}
---

<Section>
  <Container>
    <div class="grid grid-cols-1 gap-column md:grid-cols-[1fr,minmax(0,var(--media-col-max))] md:items-start md:gap-column">
      <div class="min-w-0 max-w-content flex flex-col">
        {title && (
          <h2 class="section-title">
            {title}
          </h2>
        )}
        {(body || tags.length > 0) && (
          <div class="mt-title-content flex flex-col gap-block">
            {body && (
              <div class="flex flex-col gap-block">
                {body
                  .split(/\n{2,}/)
                  .map((para, i) => para.trim())
                  .filter(Boolean)
                  .map((para, i) => (
                    <p
                      class="text-body text-text max-w-content whitespace-pre-line"
                      key={i}
                    >
                      {para}
                    </p>
                  ))}
              </div>
            )}
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-s1">
                {tags.map((tag) => (
                  <Tag>{tag}</Tag>
                ))}
              </div>
            )}
          </div>
        )}
      </div>

      {hasMedia && (
        <div class="min-w-0 w-full max-w-media-col md:max-w-full">
          {videoSrc ? (
            <video
              src={videoSrc}
              autoplay
              muted
              loop
              playsinline
              class="w-full h-auto rounded-card object-contain"
            />
          ) : (
            <img
              src={imageSrc!}
              alt=""
              width="400"
              height="300"
              class="w-full h-auto object-contain rounded-card"
              loading="lazy"
              decoding="async"
            />
          )}
        </div>
      )}
    </div>
  </Container>
</Section>
