---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Tag from '../ui/Tag.astro';
import { imagePath } from '../../lib/images';

interface WhyTrustData {
  title?: string | null;
  body?: string | null;
  tags?: string[] | null;
  image?: string | null;
}

interface Props {
  data: WhyTrustData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const body = data?.body ?? null;
const tags = data?.tags ?? [];
const imageSrc = imagePath(data?.image);

const hasContent = title || body || tags.length > 0 || imageSrc;
if (!hasContent) {
  return null;
}
---

<Section variant="muted">
  <Container>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-[1fr,minmax(0,400px)] md:items-start md:gap-12">
      <div class="min-w-0 flex flex-col gap-6">
        {title && (
          <h2 class="text-h2 text-text">
            {title}
          </h2>
        )}
        {body && (
          <p class="text-body text-text-muted max-w-xl">
            {body}
          </p>
        )}
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <Tag>{tag}</Tag>
            ))}
          </div>
        )}
      </div>

      {imageSrc && (
        <div class="min-w-0 w-full max-w-[400px] md:max-w-full">
          <img
            src={imageSrc}
            alt=""
            width="400"
            height="300"
            class="w-full h-auto object-contain rounded-soft"
            loading="lazy"
            decoding="async"
          />
        </div>
      )}
    </div>
  </Container>
</Section>
