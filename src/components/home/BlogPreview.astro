---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import { blogImagePath } from '../../lib/images';

interface BlogPreviewSectionData {
  title?: string | null;
  subtitle?: string | null;
}

interface BlogPost {
  slug: string;
  title?: string | null;
  publishDate?: string | null;
  excerpt?: string | null;
  image?: string | null;
}

interface Props {
  sectionData: BlogPreviewSectionData | null | undefined;
  posts: BlogPost[];
}

const { sectionData, posts } = Astro.props;

const DEFAULT_POST_COUNT = 4;
const title = sectionData?.title ?? null;
const subtitle = sectionData?.subtitle ?? null;

const displayedPosts = posts.slice(0, DEFAULT_POST_COUNT);
const sectionTitle = title ?? 'Блог';
const sectionSubtitle = subtitle ?? null;

function postTitle(p: BlogPost): string {
  if (typeof p.title === 'string') return p.title;
  if (p.title && typeof p.title === 'object' && 'name' in p.title) return (p.title as { name?: string }).name ?? p.slug ?? '';
  return p.slug ?? '';
}
---

<Section variant="subtle">
  <Container>
    <div class="flex flex-col gap-title-content">
      <div class="max-w-content flex flex-col gap-block">
        <h2 class="section-title">
          {sectionTitle}
        </h2>
        {sectionSubtitle && (
          <p class="text-body text-text-muted">
            {sectionSubtitle}
          </p>
        )}
      </div>

      {displayedPosts.length > 0 ? (
      <ul class="grid grid-cols-1 gap-card-gap sm:grid-cols-2 lg:grid-cols-3" role="list">
        {displayedPosts.map((post) => {
          const href = `/blog/${post.slug}`;
          const imgSrc = blogImagePath(post.slug, post.image);
          return (
            <li>
              <a
                href={href}
                class="flex flex-col gap-block rounded-soft border border-border bg-surface p-card card-hover hover:border-accent/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
              >
                {imgSrc && (
                  <div class="aspect-video w-full overflow-hidden rounded-soft bg-surface-muted">
                    <img
                      src={imgSrc}
                      alt=""
                      width="400"
                      height="225"
                      class="h-full w-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="flex min-w-0 flex-col gap-block">
                  {postTitle(post) && (
                    <h3 class="text-h3 text-text">
                      {postTitle(post)}
                    </h3>
                  )}
                  {post.publishDate && (
                    <time
                      class="text-body text-text-muted"
                      datetime={post.publishDate}
                    >
                      {new Date(post.publishDate).toLocaleDateString('ru-RU', {
                        day: 'numeric',
                        month: 'long',
                        year: 'numeric',
                      })}
                    </time>
                  )}
                  {post.excerpt && (
                    <p class="text-body text-text-muted">
                      {post.excerpt}
                    </p>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
      ) : (
        <p class="text-body text-text-muted">
          Скоро здесь появятся статьи.
        </p>
        <a href="/blog" class="text-body font-medium text-[var(--color-cta)] hover:underline">
          Перейти в блог →
        </a>
      )}
    </div>
  </Container>
</Section>
