---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';

const topicTagStyles = [
  'bg-[var(--color-accent-brand)]/10 text-[var(--color-accent-brand)] border-[var(--color-accent-brand)]/20',
  'bg-surface-muted text-text border-border',
  'bg-surface text-text-muted border-border',
];

interface ProcessData {
  title?: string | null;
  subtitle?: string | null;
  topicTags?: string[] | null;
  body?: string | null;
  cardTitle?: string | null;
  cardBody?: string | null;
}

interface Props {
  data: ProcessData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const subtitle = data?.subtitle ?? null;
const topicTags = data?.topicTags ?? [];
const body = data?.body ?? null;
const cardTitle = data?.cardTitle ?? null;
const cardBody = data?.cardBody ?? null;

const hasCard = cardTitle || cardBody;
const hasContent = title || subtitle || topicTags.length > 0 || body || hasCard;
if (!hasContent) {
  return null;
}
---

<Section>
  <Container>
    <div class:list={[
      'grid gap-column md:gap-column',
      hasCard ? 'grid-cols-1 md:grid-cols-[1fr,minmax(0,320px)] md:items-start' : 'grid-cols-1',
    ]}>
      <div class:list={[
        'min-w-0 max-w-content flex flex-col',
        !hasCard && 'mx-auto',
      ]}>
        {title && (
          <h2 class="section-title">
            {title}
          </h2>
        )}
        <div class:list={[
          'flex flex-col gap-block',
          (subtitle || topicTags.length > 0 || body) && 'mt-title-content',
        ]}>
          {subtitle && (
            <p class="text-body text-text-muted font-medium">
              {subtitle}
            </p>
          )}
          {topicTags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {topicTags.map((tag, i) => (
                <span
                  class:list={[
                    'inline-flex items-center rounded-full border px-3.5 py-2 text-small font-medium transition-colors',
                    topicTagStyles[i % topicTagStyles.length],
                  ]}
                >
                  {tag}
                </span>
              ))}
            </div>
          )}
          {body && (
            <p class="text-body text-text-muted max-w-content">
              {body}
            </p>
          )}
        </div>
      </div>

      {hasCard && (
        <div class="min-w-0 shrink-0">
          <Card>
            {cardTitle && (
              <h3 class="text-h3 text-text">
                {cardTitle}
              </h3>
            )}
            {cardBody && (
              <p class="text-body text-text-muted">
                {cardBody}
              </p>
            )}
          </Card>
        </div>
      )}
    </div>
  </Container>
</Section>
