---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';

interface FaqItem {
  question?: string | null;
  answer?: string | null;
}

interface FaqData {
  title?: string | null;
  items?: FaqItem[] | null;
}

interface Props {
  data: FaqData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const items = data?.items?.filter(
  (item) => item.question ?? item.answer
) ?? [];

const hasContent = title || items.length > 0;
if (!hasContent) {
  return null;
}
---

<Section>
  <Container>
    <div class="flex flex-col gap-8 items-center">
      {title && (
        <h2 class="text-h2 text-text font-semibold text-center max-w-2xl">
          {title}
        </h2>
      )}

      {items.length > 0 && (
        <div class="w-full max-w-2xl flex flex-col gap-3">
          {items.map((item) => (
            <details class="faq-details group rounded-card border border-border bg-surface-muted shadow-sm overflow-hidden">
              <summary class="faq-summary cursor-pointer list-none flex items-center justify-between gap-4 py-4 px-5 min-h-[3.25rem] text-left font-medium text-text hover:bg-[rgba(0,0,0,0.02)] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[var(--color-cta)]">
                <span class="text-body pr-2">{item.question ?? ''}</span>
                <span class="faq-icon shrink-0 w-8 h-8 rounded-full bg-surface border border-border flex items-center justify-center text-text-muted text-lg leading-none select-none" aria-hidden="true">
                  <span class="faq-icon-plus">+</span>
                  <span class="faq-icon-minus hidden">−</span>
                </span>
              </summary>
              <div class="faq-answer border-t border-border px-5 py-4 text-body text-text-muted leading-relaxed">
                {item.answer ? (
                  <p class="whitespace-pre-line">{item.answer}</p>
                ) : (
                  <p class="text-text-muted/80">Ответ можно добавить в админке.</p>
                )}
              </div>
            </details>
          ))}
        </div>
      )}
    </div>
  </Container>
</Section>

<style>
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-details[open] .faq-icon-plus {
    display: none;
  }
  .faq-details[open] .faq-icon-minus {
    display: inline !important;
  }
</style>
