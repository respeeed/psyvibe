---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';
import { imagePath } from '../../lib/images';

interface DiagnosticData {
  title?: string | null;
  intro?: string | null;
  resultCards?: Array<{
    icon?: string | null;
    iconBackground?: 'surface' | 'surface-muted' | 'accent' | null;
    title?: string | null;
    description?: string | null;
  }> | null;
  ctaLabel?: string | null;
  ctaUrl?: string | null;
}

const iconBgClasses: Record<string, string> = {
  surface: 'bg-surface text-text-muted',
  'surface-muted': 'bg-surface-muted text-text-muted',
  accent: 'bg-accent-brand text-text-inverse',
};

interface Props {
  data: DiagnosticData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const intro = data?.intro ?? null;
const resultCards = data?.resultCards?.filter(
  (c) => c.title ?? c.description
) ?? [];
const ctaLabel = data?.ctaLabel ?? null;
const ctaUrl = data?.ctaUrl ?? null;
const hasButton = ctaLabel && ctaUrl;

const hasContent = title || intro || resultCards.length > 0 || hasButton;
if (!hasContent) {
  return null;
}
---

<Section variant="subtle" id="diagnostic">
  <Container>
    <div class="flex flex-col gap-title-content items-center">
      <div class="max-w-content w-full text-center">
        {title && (
          <h2 class="section-title text-center">
            {title}
          </h2>
        )}
        {intro && (
          <p class="mt-title-content text-body text-text">
            {intro}
          </p>
        )}
      </div>

      {(resultCards.length > 0 || hasButton) && (
        <div class="flex flex-col gap-cta-gap w-full items-center">
          {resultCards.length > 0 && (
            <ul class="grid grid-cols-1 gap-card-gap sm:grid-cols-2 w-full" role="list">
              {resultCards.map((card) => {
                const iconSrc = imagePath(card.icon);
                const bgClass = iconBgClasses[card.iconBackground ?? 'surface'] ?? iconBgClasses.surface;
                return (
                  <li>
                    <Card>
                      {iconSrc && (
                        <div class={`flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-soft shrink-0 mb-3 ${bgClass}`}>
                          <img src={iconSrc} alt="" width="24" height="24" class="w-5 h-5 md:w-6 md:h-6 object-contain" loading="lazy" />
                        </div>
                      )}
                      {card.title && (
                        <h3 class="text-h3 text-text">
                          {card.title}
                        </h3>
                      )}
                      {card.description && (
                        <p class="text-body text-text-muted">
                          {card.description}
                        </p>
                      )}
                    </Card>
                  </li>
                );
              })}
            </ul>
          )}
          {hasButton && (
            <div class="flex flex-wrap justify-center w-full">
              <Button href={ctaUrl} variant="primary">
                {ctaLabel}
              </Button>
            </div>
          )}
        </div>
      )}
    </div>
  </Container>
</Section>
