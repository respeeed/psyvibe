---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';
import { imagePath } from '../../lib/images';

interface ResultsColumn {
  icon?: string | null;
  title?: string | null;
  subtitle?: string | null;
  context?: string | null;
  items?: string[] | null;
}

interface ResultsData {
  title?: string | null;
  columns?: ResultsColumn[] | null;
}

interface Props {
  data: ResultsData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const columns = data?.columns?.filter(
  (col) => col.title ?? (col.items?.length ?? 0) > 0
) ?? [];

const hasContent = title || columns.length > 0;
if (!hasContent) {
  return null;
}

const resultsColumnIcons = [
  /* весы / баланс */
  '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 md:w-6 md:h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13 3.947m-2 0l-2 11.106m0 0l-2 2.5m2-13.606l2 2.5" /></svg>',
  /* столбцы / аналитика */
  '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 md:w-6 md:h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>',
  /* искры / рост */
  '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 md:w-6 md:h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>',
];
---

<Section variant="subtle">
  <Container>
    <div class="flex flex-col gap-title-content items-center">
      {title && (
        <h2 class="section-title text-center max-w-content">
          {title}
        </h2>
      )}

      {columns.length > 0 && (
        <ul
          class="grid grid-cols-1 gap-card-gap sm:grid-cols-2 lg:grid-cols-3 w-full"
          role="list"
        >
          {columns.map((col, i) => {
            const iconSrc = imagePath(col.icon);
            return (
            <li>
              <Card class="h-full flex flex-col">
                {iconSrc ? (
                  <span
                    class="flex items-center justify-center w-[6.5rem] h-[6.5rem] md:w-[7.75rem] md:h-[7.75rem] rounded-soft shrink-0 bg-surface-muted/80 overflow-hidden self-center my-4"
                    aria-hidden="true"
                  >
                    <img
                      src={iconSrc}
                      alt=""
                      width="96"
                      height="96"
                      class="w-full h-full object-contain"
                      loading="lazy"
                    />
                  </span>
                ) : (
                  <span
                    class="flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-soft shrink-0 bg-surface-muted text-text-muted border border-border/60 self-center my-4"
                    aria-hidden="true"
                  >
                    <span set:html={resultsColumnIcons[i % resultsColumnIcons.length]} />
                  </span>
                )}
                <div class="flex flex-col gap-0">
                  {col.title && (
                    <h3 class="text-lg font-semibold text-heading leading-tight">
                      {col.title}
                    </h3>
                  )}
                  {col.subtitle && (
                    <p class="text-small text-text-muted mt-2">
                      {col.subtitle}
                    </p>
                  )}
                </div>
                {col.context && (
                  <p class="text-body text-text mt-block font-medium">
                    {col.context}
                  </p>
                )}
                {col.items && col.items.length > 0 && (
                  <ul class="mt-block space-y-2 text-body text-text-muted" role="list">
                    {col.items.map((item) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                          </svg>
                        </span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </Card>
            </li>
            );
          })}
        </ul>
      )}
    </div>
  </Container>
</Section>
