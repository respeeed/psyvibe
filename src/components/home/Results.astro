---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';

interface ResultsColumn {
  title?: string | null;
  subtitle?: string | null;
  context?: string | null;
  items?: string[] | null;
}

interface ResultsData {
  title?: string | null;
  columns?: ResultsColumn[] | null;
}

interface Props {
  data: ResultsData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const columns = data?.columns?.filter(
  (col) => col.title ?? (col.items?.length ?? 0) > 0
) ?? [];

const hasContent = title || columns.length > 0;
if (!hasContent) {
  return null;
}
---

<Section variant="muted">
  <Container>
    <div class="flex flex-col gap-title-content items-center">
      {title && (
        <h2 class="section-title text-center max-w-content">
          {title}
        </h2>
      )}

      {columns.length > 0 && (
        <ul
          class="grid grid-cols-1 gap-card-gap sm:grid-cols-2 lg:grid-cols-3 w-full"
          role="list"
        >
          {columns.map((col) => (
            <li>
              <Card class="h-full flex flex-col">
                {col.title && (
                  <h3 class="text-lg font-semibold text-text leading-tight">
                    {col.title}
                  </h3>
                )}
                {col.subtitle && (
                  <p class="text-small text-text-muted mt-block">
                    {col.subtitle}
                  </p>
                )}
                {col.context && (
                  <p class="text-body text-text mt-block font-medium">
                    {col.context}
                  </p>
                )}
                {col.items && col.items.length > 0 && (
                  <ul class="mt-block space-y-2 text-body text-text-muted" role="list">
                    {col.items.map((item) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-0.5 shrink-0 text-text-muted" aria-hidden="true">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                          </svg>
                        </span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </Card>
            </li>
          ))}
        </ul>
      )}
    </div>
  </Container>
</Section>
