---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import { imagePath, videoPath } from '../../lib/images';

interface HeroData {
  title?: string | null;
  subtitle?: string | null;
  primaryCtaLabel?: string | null;
  primaryCtaUrl?: string | null;
  secondaryCtaLabel?: string | null;
  secondaryCtaUrl?: string | null;
  workingHours?: string | null;
  image?: string | null;
  video?: string | null;
  stats?: Array<{ value?: string | null; label?: string | null }> | null;
}

interface Props {
  hero: HeroData | null | undefined;
}

const { hero } = Astro.props;

const title = hero?.title ?? 'Главная';
const subtitle = hero?.subtitle ?? null;
const primaryCtaLabel = hero?.primaryCtaLabel ?? null;
const primaryCtaUrl = hero?.primaryCtaUrl ?? null;
const secondaryCtaLabel = hero?.secondaryCtaLabel ?? null;
const secondaryCtaUrl = hero?.secondaryCtaUrl ?? null;
const workingHours = hero?.workingHours ?? null;
const stats = hero?.stats?.filter((s) => s.value ?? s.label) ?? [];

const heroVideoSrc = videoPath(hero?.video);
const heroImageSrc = imagePath(hero?.image) ?? '/images/hero-girl.png';
const hasVideo = heroVideoSrc != null;

const hasPrimaryCta = primaryCtaLabel && primaryCtaUrl;
const hasSecondaryCta = secondaryCtaLabel && secondaryCtaUrl;
const hasCtas = hasPrimaryCta || hasSecondaryCta;

// Плейсхолдер только для layout нижней карточки (schema не меняем)
const heroCardName = 'Елизавета Шихалева';
const heroCardTags = ['Корпоративный психолог', 'КПТ', 'Стресс и выгорание'];
const heroCardQuote = 'Когда команда в ресурсе — бизнес растёт. Помогаю создавать условия, в которых людям хорошо работать.';

const highlightPhrase = 'Лучше цифры.';
const titleSafe = (title ?? '')
  .replace(/&/g, '&amp;')
  .replace(/</g, '&lt;')
  .replace(/>/g, '&gt;');
const titleHtml = titleSafe.replace(
  new RegExp(highlightPhrase.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi'),
  `<span style="color: var(--color-accent-brand)">${highlightPhrase}</span>`
);
---

<Section class="hero-section pt-hero-top pb-hero-bottom">
  <Container class="mb-16 md:mb-20">
    <div class="flex flex-col gap-hero-gap max-w-content mx-auto text-center items-center w-full">
      <h1 class="text-[clamp(2.5rem,6vw,3.75rem)] font-bold text-text leading-[1.15] tracking-tight" set:html={titleHtml} />
      {subtitle && (
        <p class="text-body text-text max-w-xl leading-relaxed font-normal">
          {subtitle}
        </p>
      )}
      {hasCtas && (
        <div class="flex flex-wrap gap-3 justify-center">
          {hasPrimaryCta && (
            <Button href={primaryCtaUrl} variant="primary">
              {primaryCtaLabel}
            </Button>
          )}
          {hasSecondaryCta && (
            <Button href={secondaryCtaUrl} variant="secondary">
              {secondaryCtaLabel}
            </Button>
          )}
        </div>
      )}
      {workingHours && (
        <p class="text-small text-text-muted mt-s2">
          {workingHours}
        </p>
      )}
    </div>
  </Container>

  <!-- Иллюстрация: рамка, градиент, карточка (премиальный блок) + параллакс на десктопе -->
  <div class="w-full px-[var(--container-padding)]">
    <div id="hero-media-wrapper" class="max-w-6xl mx-auto relative w-full aspect-[4/3] md:aspect-[2/1] bg-surface-muted rounded-2xl md:rounded-3xl overflow-hidden shadow-[var(--hero-media-shadow)] will-change-transform">
      {hasVideo ? (
        <video
          src={heroVideoSrc!}
          autoplay
          muted
          loop
          playsinline
          class="absolute inset-0 w-full h-full object-cover"
          aria-label="Видео о формате работы"
        />
      ) : (
        <img
          src={heroImageSrc}
          alt=""
          width="1920"
          height="960"
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
      )}
      <!-- Мягкий градиент снизу: карточка лучше читается на фоне -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: linear-gradient(to top, rgba(var(--color-shadow-rgb), 0.32) 0%, transparent 40%);" />

      <!-- Нижняя карточка: висящая над иллюстрацией (desktop), премиальный стиль + анимация при скролле -->
      <div id="hero-floating-card" class="hero-card-scroll-anim absolute left-0 right-0 bottom-5 md:bottom-6 z-10 hidden md:block px-4 md:px-6">
        <div class="max-w-container mx-auto rounded-2xl overflow-hidden backdrop-blur-xl border border-white/60 shadow-[var(--hero-card-shadow)]" style="background: linear-gradient(180deg, rgba(250,251,255,0.9) 0%, rgba(243,247,255,0.9) 100%);">
          <div class="grid grid-cols-1 md:grid-cols-[1fr,1.15fr] gap-8 md:gap-0 items-stretch p-6 md:p-8">
            <div class="min-w-0 flex flex-col justify-center gap-4">
              <p class="text-xl md:text-2xl font-semibold text-text leading-tight tracking-tight">
                {heroCardName}
              </p>
              <div class="flex flex-wrap gap-2">
                {heroCardTags.map((tag) => (
                  <span class="inline-flex items-center rounded-full border border-white/50 bg-white/45 px-3 py-1.5 text-small font-medium text-text">
                    {tag}
                  </span>
                ))}
              </div>
              {workingHours && (
                <p class="text-small text-text-muted pt-0.5 border-t border-border/50 mt-1">
                  {workingHours}
                </p>
              )}
            </div>
            <div class="min-w-0 flex items-center gap-5 md:pl-8 md:border-l border-border/60">
              <span class="shrink-0 text-[var(--color-text-muted)]/35" aria-hidden="true">
                <svg class="w-8 h-8 md:w-9 md:h-9" viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M27 20C17.6467 20 10 27.6467 10 37C10 46.3533 17.6467 54 27 54C30.5533 54 33.8548 52.8893 36.5898 51.0078C34.8538 58.4314 31.76 63.6016 28.7148 67.1797C24.1368 72.5589 19.8867 74.2148 19.8867 74.2148C19.5117 74.3543 19.1683 74.5674 18.8768 74.8415C18.5853 75.1156 18.3516 75.4453 18.1895 75.8111C18.0273 76.1769 17.94 76.5715 17.9325 76.9715C17.9251 77.3716 17.9978 77.7691 18.1464 78.1407C18.2949 78.5122 18.5162 78.8503 18.7973 79.135C19.0785 79.4198 19.4137 79.6454 19.7834 79.7986C20.153 79.9519 20.5496 80.0296 20.9497 80.0273C21.3498 80.025 21.7454 79.9427 22.1133 79.7852C22.1133 79.7852 27.8632 77.4411 33.2852 71.0703C38.7071 64.6995 44 54.1452 44 38C44.0001 37.8549 43.9896 37.71 43.9688 37.5664C43.9751 37.3765 44 37.1914 44 37C44 27.6467 36.3533 20 27 20ZM69 20C59.6467 20 52 27.6467 52 37C52 46.3533 59.6467 54 69 54C72.5533 54 75.8548 52.8893 78.5898 51.0078C76.8538 58.4314 73.76 63.6016 70.7148 67.1797C66.1368 72.5589 61.8867 74.2148 61.8867 74.2148C61.5117 74.3543 61.1683 74.5674 60.8768 74.8415C60.5853 75.1156 60.3516 75.4453 60.1895 75.8111C60.0273 76.1769 59.94 76.5715 59.9326 76.9715C59.9251 77.3716 59.9978 77.7691 60.1464 78.1407C60.2949 78.5122 60.5162 78.8503 60.7974 79.135C61.0785 79.4198 61.4137 79.6454 61.7834 79.7986C62.153 79.9519 62.5496 80.0296 62.9497 80.0273C63.3498 80.025 63.7454 79.9427 64.1133 79.7852C64.1133 79.7852 69.8632 77.4411 75.2852 71.0703C80.7071 64.6995 86 54.1452 86 38C86.0001 37.8549 85.9896 37.71 85.9688 37.5664C85.9751 37.3765 86 37.1914 86 37C86 27.6467 78.3533 20 69 20ZM27 26C33.1107 26 38 30.8893 38 37C38 43.1107 33.1107 48 27 48C20.8893 48 16 43.1107 16 37C16 30.8893 20.8893 26 27 26ZM69 26C75.1107 26 80 30.8893 80 37C80 43.1107 75.1107 48 69 48C62.8893 48 58 43.1107 58 37C58 30.8893 62.8893 26 69 26Z" fill="currentColor"/>
                </svg>
              </span>
              <p class="text-[1.0625rem] text-text leading-relaxed font-light">
                {heroCardQuote}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile: карточка под иллюстрацией (лёгкий нахлёст на рамку) -->
    <div class="md:hidden -mt-6 pb-s3">
      <div class="rounded-2xl border border-border p-card shadow-[var(--hero-card-mobile-shadow)] flex flex-col gap-3" style="background-color: rgb(248, 250, 255);">
        <p class="text-lg font-semibold text-text leading-tight">
          {heroCardName}
        </p>
        <div class="flex flex-wrap gap-2">
          {heroCardTags.map((tag) => (
            <span class="inline-flex items-center rounded-full border border-white/50 bg-white/45 px-3 py-1.5 text-small font-medium text-text">
              {tag}
            </span>
          ))}
        </div>
        <p class="text-[1.0625rem] text-text font-light leading-relaxed italic">
          {heroCardQuote}
        </p>
        {workingHours && (
          <p class="text-small text-text-muted mt-s2">
            {workingHours}
          </p>
        )}
      </div>
    </div>
  </div>
</Section>

<script>
  (function () {
    const card = document.getElementById('hero-floating-card');
    const wrapper = document.getElementById('hero-media-wrapper');
    const heroMedia = card?.closest('.max-w-6xl');
    if (!card || !heroMedia) return;

    // Анимация появления карточки
    const observer = new IntersectionObserver(
      (entries) => {
        const entry = entries[0];
        if (!entry?.isIntersecting) return;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => card.classList.add('hero-card-visible'));
        });
        observer.disconnect();
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0 }
    );
    observer.observe(heroMedia);

    // Плавное движение всего блока при скролле (только десктоп)
    if (!wrapper) return;
    const desktop = window.matchMedia('(min-width: 768px)');
    let ticking = false;

    function updateParallax() {
      if (!desktop.matches) {
        wrapper.style.transform = '';
        ticking = false;
        return;
      }
      const rect = wrapper.getBoundingClientRect();
      const move = Math.max(-18, Math.min(18, -rect.top * 0.06));
      wrapper.style.transform = `translateY(${move}px)`;
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    desktop.addEventListener('change', () => { if (!desktop.matches) wrapper.style.transform = ''; });
    updateParallax();
  })();
</script>
