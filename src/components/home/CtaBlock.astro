---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';

interface CtaBlockData {
  title?: string | null;
  ctaLabel?: string | null;
  ctaUrl?: string | null;
}

interface Props {
  data: CtaBlockData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const ctaLabel = data?.ctaLabel ?? null;
const ctaUrl = data?.ctaUrl ?? null;
const hasButton = ctaLabel && ctaUrl;

// Выделяем фразу «улучшение состояния команды» цветом и жирным (призыв)
const highlightPhrase = 'улучшение состояния команды';
const titleHtml = title
  ? title.replace(
      new RegExp(highlightPhrase.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi'),
      `<span class="text-[var(--color-accent-brand)] font-semibold">$&</span>`
    )
  : null;

const hasContent = title || hasButton;
if (!hasContent) {
  return null;
}
---

<Section>
  <Container>
    <div class="w-full flex flex-col items-center gap-title-content text-center">
      {titleHtml && (
        <p class="text-display font-light text-text leading-tight max-w-content mx-auto" set:html={titleHtml} />
      )}
      {hasButton && (
        <Button href={ctaUrl} variant="primary">
          {ctaLabel}
        </Button>
      )}
    </div>
  </Container>
</Section>
