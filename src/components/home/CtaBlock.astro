---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';

interface CtaBlockData {
  title?: string | null;
  ctaLabel?: string | null;
  ctaUrl?: string | null;
}

interface Props {
  data: CtaBlockData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const ctaLabel = data?.ctaLabel ?? null;
const ctaUrl = data?.ctaUrl ?? null;
const hasButton = ctaLabel && ctaUrl;

// Выделяем слова «состояния» и «команды» жирным (контент из CMS)
const titleHtml = title
  ? title.replace(/\b(состояния|команды)\b/gi, '<strong>$1</strong>')
  : null;

const hasContent = title || hasButton;
if (!hasContent) {
  return null;
}
---

<Section>
  <Container>
    <div class="w-full rounded-card bg-surface-muted py-cta-block px-card flex flex-col items-center gap-cta-gap text-center shadow-[var(--card-shadow)] border border-border/60">
      {titleHtml && (
        <p class="text-body text-text-muted leading-relaxed max-w-content mx-auto" set:html={titleHtml} />
      )}
      {hasButton && (
        <Button href={ctaUrl} variant="primary">
          {ctaLabel}
        </Button>
      )}
    </div>
  </Container>
</Section>
