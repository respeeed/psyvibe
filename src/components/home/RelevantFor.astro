---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import { imagePath } from '../../lib/images';

interface RelevantForData {
  title?: string | null;
  iconItems?: Array<{
    icon?: string | null;
    iconBackground?: 'surface' | 'surface-muted' | 'accent' | null;
    text?: string | null;
  }> | null;
  secondaryTitle?: string | null;
  tags?: string[] | null;
  ctaLabel?: string | null;
  ctaUrl?: string | null;
}

const iconBgClasses: Record<string, string> = {
  surface: 'bg-surface text-text-muted border border-border/60',
  'surface-muted': 'bg-surface-muted text-text-muted border border-border/60',
  accent: 'bg-accent-brand text-text-inverse border-transparent',
};

interface Props {
  data: RelevantForData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const iconItems = data?.iconItems?.filter((i) => i.text) ?? [];
const secondaryTitle = data?.secondaryTitle ?? null;
const tags = data?.tags?.filter(Boolean) ?? [];
const ctaLabel = data?.ctaLabel ?? null;
const ctaUrl = data?.ctaUrl ?? null;
const hasCta = ctaLabel && ctaUrl;

const hasContent = title || iconItems.length > 0 || secondaryTitle || tags.length > 0 || hasCta;
if (!hasContent) {
  return null;
}
---

<Section>
  <Container>
    <div class="flex flex-col items-center gap-8 text-center">
      {title && (
        <h2 class="section-title max-w-content text-text">
          {title}
        </h2>
      )}

      {iconItems.length > 0 && (
        <ul class="w-full grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-content" role="list">
          {iconItems.map((item) => {
            const iconSrc = imagePath(item.icon);
            const bgClass = iconBgClasses[item.iconBackground ?? 'surface-muted'] ?? iconBgClasses['surface-muted'];
            return (
              <li class="flex flex-col items-center gap-block">
                <div class={`w-12 h-12 md:w-[4.5rem] md:h-[4.5rem] rounded-soft flex items-center justify-center shrink-0 overflow-hidden p-4 ${bgClass}`}>
                  {iconSrc ? (
                    <img
                      src={iconSrc}
                      alt=""
                      width="48"
                      height="48"
                      class="w-full h-full object-contain"
                      loading="lazy"
                    />
                  ) : (
                    <svg class="w-5 h-5 md:w-6 md:h-6 [color:inherit]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25a2.25 2.25 0 0 0 2.25 2.25h14.5a2.25 2.25 0 0 0 2.25-2.25V3.75A2.25 2.25 0 0 0 20.25 1.5H5.25A2.25 2.25 0 0 0 3 3.75Zm6 9.75h.008v.008H9V13.5Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm3-.375h.008v.008H12.375V13.5Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm3-.375h.008v.008H15.75V13.5Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                    </svg>
                  )}
                </div>
                <p class="text-body text-text-muted leading-snug max-w-[10rem]">
                  {item.text}
                </p>
              </li>
            );
          })}
        </ul>
      )}

      {(secondaryTitle || tags.length > 0 || hasCta) && (
        <div class="flex flex-col items-center w-full mt-6">
          {(secondaryTitle || tags.length > 0) && (
            <div class="flex flex-col items-center gap-4">
              {secondaryTitle && (
                <h3 class="text-xl font-semibold text-text">
                  {secondaryTitle}
                </h3>
              )}
              {tags.length > 0 && (
                <ul class="flex flex-wrap justify-center gap-2" role="list">
                  {tags.map((tag) => (
                    <li>
                      <span class="inline-flex rounded-full border border-border bg-surface-subtle px-4 py-2 text-body text-text">
                        {tag}
                      </span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          )}
          {hasCta && (
            <a
              href={ctaUrl}
              class="mt-10 inline-flex items-center justify-center gap-2 rounded-lg px-5 py-2.5 text-body font-medium bg-[var(--color-cta)] text-white hover:bg-[var(--color-cta-hover)] active:bg-[var(--color-cta-active)] transition-colors shadow-lg hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-cta)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-surface)]"
            >
              {ctaLabel}
            </a>
          )}
        </div>
      )}
    </div>
  </Container>
</Section>
