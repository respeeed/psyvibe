---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';

interface DiscussBlockData {
  title?: string | null;
  body?: string | null;
  listItems?: string[] | null;
  ctaLabel?: string | null;
  ctaUrl?: string | null;
  contactEmail?: string | null;
}

type SiteSettings = Awaited<ReturnType<typeof import('../../lib/keystatic').reader.singletons.siteSettings.read>> | null | undefined;

interface Props {
  data: DiscussBlockData | null | undefined;
  siteSettings?: SiteSettings;
}

const { data, siteSettings } = Astro.props;

const title = data?.title ?? null;
const body = data?.body ?? null;
const listItems = data?.listItems ?? [];
const ctaLabel = data?.ctaLabel ?? null;
const ctaUrl = data?.ctaUrl ?? null;
const contactEmail = data?.contactEmail ?? null;
const messengerUrl = siteSettings?.messengerUrl ?? null;

const hasContent = title || body || listItems.length > 0;
const hasPrimaryCta = ctaLabel && ctaUrl;
const hasContacts = messengerUrl || contactEmail;

if (!hasContent && !hasPrimaryCta && !hasContacts) {
  return null;
}
---

<Section>
  <Container>
    <div class="w-full max-w-content mx-auto rounded-card bg-surface-muted border border-border/60 shadow-[0_2px_8px_rgba(28,25,23,0.06)] py-cta-block px-card">
      <div class="flex flex-col gap-title-content text-center">
        {title && (
          <h2 class="section-title">
            {title}
          </h2>
        )}
        {(body || listItems.length > 0) && (
          <div class="flex flex-col gap-4 -mt-4">
            {body && (
              <p class="text-body text-text-muted">
                {body}
              </p>
            )}
            {listItems.length > 0 && (
              <ul class="grid grid-cols-3 justify-items-center gap-6 md:gap-10 list-none m-0 p-0 w-full max-w-2xl mx-auto" role="list">
                {listItems.map((item, i) => {
                  const icons = [
                    /* выгорание / риски */
                    '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 md:w-10 md:h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13 3.947m-2 0l-2 11.106m0 0l-2 2.5m2-13.606l2 2.5" /></svg>',
                    /* текучка / факторы */
                    '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 md:w-10 md:h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>',
                    /* формат / внедрение */
                    '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 md:w-10 md:h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>',
                  ];
                  const icon = icons[i % icons.length];
                  return (
                    <li class="flex flex-col items-center gap-1.5 text-center max-w-[14rem]">
                      <span class="flex items-center justify-center w-14 h-14 md:w-16 md:h-16 rounded-full bg-surface border border-border/80 text-text-muted" set:html={icon} />
                      <span class="text-small text-text-muted leading-snug">{item}</span>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>
        )}

        <div class="flex flex-col items-center gap-4 pt-6">
          {hasPrimaryCta && (
            <Button href={ctaUrl} variant="primary">
              {ctaLabel}
            </Button>
          )}
          <div class="flex flex-col items-center gap-2">
            {hasContacts && (
              <p class="text-small text-text-muted text-center">
                Или напишите
                {messengerUrl && (
                  <>
                    <a href={messengerUrl} class="text-accent-brand hover:text-accent-brand-hover underline ml-1" target="_blank" rel="noopener noreferrer">в Telegram</a>
                    {contactEmail && ' или '}
                  </>
                )}
                {contactEmail && (
                  <a href={`mailto:${contactEmail}`} class="text-accent-brand hover:text-accent-brand-hover underline ml-1">на почту</a>
                )}.
              </p>
            )}
            <p class="text-small text-text-muted text-center">
              Ответ обычно в течение 1 рабочего дня.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>
