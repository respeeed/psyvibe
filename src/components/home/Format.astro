---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import { imagePath, videoPath } from '../../lib/images';

interface FormatData {
  title?: string | null;
  body?: string | null;
  listItems?: string[] | null;
  priceText?: string | null;
  priceNote?: string | null;
  image?: string | null;
  video?: string | null;
}

interface Props {
  data: FormatData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const body = data?.body ?? null;
const listItems = data?.listItems ?? [];
const priceText = data?.priceText ?? null;
const priceNote = data?.priceNote ?? null;
const imageSrc = imagePath(data?.image);
const videoSrc = videoPath(data?.video);
const hasMedia = imageSrc ?? videoSrc;

const hasPrice = priceText ?? priceNote;
const hasContent =
  title || body || listItems.length > 0 || hasPrice || hasMedia;
if (!hasContent) {
  return null;
}
---

<Section variant="dark">
  <Container>
    <div class="text-text-inverse py-cta-block">
      <div
        class:list={[
          'grid grid-cols-1 gap-column md:gap-column',
          hasMedia
            ? 'md:grid-cols-[1fr,minmax(0,var(--media-col-max))] md:items-start'
            : 'justify-items-center',
        ]}
      >
        <div class:list={[
          'min-w-0 max-w-content flex flex-col gap-block w-full',
          !hasMedia && 'mx-auto',
        ]}>
          {title && (
            <h2 class="section-title text-text-inverse">
              {title}
            </h2>
          )}
          {body && (
            <p class="text-body text-text-muted-inverse">
              {body}
            </p>
          )}
          {listItems.length > 0 && (
            <ul class="list-disc list-inside space-y-2 text-body text-text-muted-inverse">
              {listItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
          {(priceText || priceNote) && (
            <div class="flex flex-col gap-block mt-block">
              {priceText && (
                <p class="text-lg font-semibold text-text-inverse bg-white/10 rounded-soft px-4 py-3 w-fit">
                  {priceText}
                </p>
              )}
              {priceNote && (
                <p class="text-body text-text-muted-inverse">
                  {priceNote}
                </p>
              )}
            </div>
          )}
        </div>

        {hasMedia && (
          <div class="min-w-0 w-full max-w-media-col md:max-w-full">
            {videoSrc ? (
              <video
                src={videoSrc}
                autoplay
                muted
                loop
                playsinline
                class="w-full h-auto rounded-soft object-contain"
              />
            ) : (
              <img
                src={imageSrc!}
                alt=""
                width="400"
                height="300"
                class="w-full h-auto object-contain rounded-soft"
                loading="lazy"
                decoding="async"
              />
            )}
          </div>
        )}
      </div>
    </div>
  </Container>
</Section>
