---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import { imagePath, videoPath } from '../../lib/images';

interface BenefitsData {
  title?: string | null;
  subtitle?: string | null;
  body?: string | null;
  listItems?: string[] | null;
  image?: string | null;
  video?: string | null;
}

interface Props {
  data: BenefitsData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const subtitleRaw = data?.subtitle ?? null;
const body = data?.body ?? null;
const listItems = data?.listItems ?? [];
const imageSrc = imagePath(data?.image);
const videoSrc = videoPath(data?.video);
const hasMedia = imageSrc ?? videoSrc;

const hasContent = title || body || listItems.length > 0 || hasMedia;
if (!hasContent) {
  return null;
}

function normalizeText(input: string | null | undefined) {
  // В контенте иногда используется "\L" как мягкий перенос.
  return (input ?? '').replace(/\\L/g, '\n');
}

const bodyText = normalizeText(body);
const subtitleText = subtitleRaw ? normalizeText(subtitleRaw).trim() : null;

let bodyLead: string | null = null;
let bodyRemainder: string | null = null;

if (subtitleText) {
  bodyLead = subtitleText;
  if (bodyText.startsWith(subtitleText)) {
    bodyRemainder = bodyText.slice(subtitleText.length).trimStart();
  } else {
    bodyRemainder = bodyText.trim() || null;
  }
} else {
  const firstPeriodIndex = bodyText.indexOf('.');
  bodyLead =
    firstPeriodIndex >= 0 ? bodyText.slice(0, firstPeriodIndex + 1).trim() : null;
  bodyRemainder =
    firstPeriodIndex >= 0 ? bodyText.slice(firstPeriodIndex + 1).trim() : null;
}
---

<Section variant="muted">
  <Container>
    <div class="grid grid-cols-1 gap-column md:grid-cols-[1fr,minmax(0,var(--media-col-max))] md:items-start md:gap-column">
      <div class="min-w-0 max-w-content flex flex-col">
        {title && (
          <h2 class="section-title">
            {title}
          </h2>
        )}
        {(body || listItems.length > 0) && (
          <div class="mt-title-content flex flex-col gap-block">
            {body && (
              <div class="flex flex-col gap-block">
                {bodyLead && (
                  <p class="text-body text-text font-semibold max-w-content">
                    {bodyLead}
                  </p>
                )}
                {bodyRemainder && (
                  <p class="text-body text-text-muted max-w-content whitespace-pre-line">
                    {bodyRemainder}
                  </p>
                )}
              </div>
            )}
            {listItems.length > 0 && (
              <ul class="list-disc list-inside space-y-2 text-body text-text max-w-content">
                {listItems.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </div>
        )}
      </div>

      {hasMedia && (
        <div class="min-w-0 w-full max-w-media-col md:max-w-full">
          {videoSrc ? (
            <video
              src={videoSrc}
              autoplay
              muted
              loop
              playsinline
              class="w-full h-auto rounded-card object-contain"
            />
          ) : (
            <img
              src={imageSrc!}
              alt=""
              width="400"
              height="300"
              class="w-full h-auto object-contain rounded-card"
              loading="lazy"
              decoding="async"
            />
          )}
        </div>
      )}
    </div>
  </Container>
</Section>
