---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';

interface Step {
  title?: string | null;
  description?: string | null;
}

interface HowItWorksData {
  title?: string | null;
  steps?: Step[] | null;
}

interface Props {
  data: HowItWorksData | null | undefined;
}

const { data } = Astro.props;

const title = data?.title ?? null;
const steps = data?.steps?.filter(
  (s) => s.title ?? s.description
) ?? [];

const hasContent = title || steps.length > 0;
if (!hasContent) {
  return null;
}
---

<Section variant="muted">
  <Container>
    <div class="flex flex-col gap-10 md:gap-12">
      {title && (
        <h2 class="section-title text-center text-text">
          {title}
        </h2>
      )}

      {steps.length > 0 && (
        <ol
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-2 gap-y-4 md:gap-x-3 md:gap-y-6 list-none m-0 p-0"
          role="list"
        >
          {steps.map((step, i) => (
            <li class="flex flex-col">
              <Card class="h-full flex flex-col gap-block">
                <span
                  class="text-small font-medium text-text-muted tabular-nums"
                  aria-hidden="true"
                >
                  {String(i + 1).padStart(2, '0')}
                </span>
                {step.title && (
                  <h3 class="text-h3 text-text mt-0">
                    {step.title}
                  </h3>
                )}
                {step.description && (
                  <p class="text-body text-text-muted mt-0 flex-1">
                    {step.description}
                  </p>
                )}
              </Card>
            </li>
          ))}
        </ol>
      )}
    </div>
  </Container>
</Section>
