---
import Container from '../ui/Container.astro';

interface Props {
  siteSettings?: Awaited<ReturnType<typeof import('../../lib/keystatic').reader.singletons.siteSettings.read>> | null;
}

const { siteSettings } = Astro.props;
const siteName = siteSettings?.siteName ?? 'Psy-vibe';
const navLinks = siteSettings?.navLinks ?? [];
const phone = siteSettings?.phone ?? '';
const messengerUrl = siteSettings?.messengerUrl ?? null;

const hasContacts = phone || messengerUrl;
---

<header class="border-b border-border/40">
  <Container class="py-3 md:py-4">
    <div class="flex flex-row items-center justify-between gap-6 min-h-[2.75rem]">
      <a href="/" class="font-medium text-text hover:text-accent text-body shrink-0 tracking-tight">
        {siteName}
      </a>

      <div class="flex flex-wrap items-center justify-end gap-x-5 gap-y-2 md:gap-x-8">
        {navLinks.length > 0 && (
          <nav class="contents" aria-label="Основная навигация">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class="text-small text-text-muted hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            ))}
          </nav>
        )}
        {phone && (
          <a
            href={`tel:${phone.replace(/\s/g, '')}`}
            class="text-small text-text-muted hover:text-accent transition-colors whitespace-nowrap hidden sm:inline"
          >
            {phone}
          </a>
        )}
        {messengerUrl && (
          <a
            href={messengerUrl}
            class="text-small text-text-muted hover:text-accent transition-colors hidden sm:inline"
            aria-label="Написать в мессенджер"
          >
            Мессенджер ↗
          </a>
        )}
        <a
          href="#diagnostic"
          class="shrink-0 inline-flex items-center justify-center rounded-soft px-4 py-2 text-small font-medium border border-border text-text hover:border-accent hover:text-accent transition-colors"
        >
          Записаться на диагностику
        </a>
      </div>
    </div>
  </Container>
</header>
