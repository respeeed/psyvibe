---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';

interface Props {
  siteSettings?: Awaited<ReturnType<typeof import('../../lib/keystatic').reader.singletons.siteSettings.read>> | null;
}

const { siteSettings } = Astro.props;
const siteName = siteSettings?.siteName ?? 'Psy-vibe';
const navLinks = siteSettings?.navLinks ?? [];
const phone = siteSettings?.phone ?? '';
const messengerUrl = siteSettings?.messengerUrl ?? null;
const copyright = siteSettings?.copyright ?? '';

const hasContacts = phone || messengerUrl;
---

<footer class="mt-auto border-t border-border bg-surface-muted">
  <Container class="py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between md:gap-12">
      <div class="flex flex-wrap items-center gap-6">
        <div class="flex flex-col gap-2">
          <a href="/" class="font-medium text-text hover:text-accent text-body focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-cta)] focus-visible:ring-offset-2 rounded-sm">
            {siteName}
          </a>
          {copyright && (
            <p class="text-small text-text-muted">{copyright}</p>
          )}
        </div>
        {navLinks.length > 0 && (
          <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Навигация в подвале">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class="text-small text-text-muted hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-cta)] focus-visible:ring-offset-2 rounded-sm"
              >
                {link.label}
              </a>
            ))}
          </nav>
        )}
        {hasContacts && (
          <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
            {phone && (
              <a
                href={`tel:${phone.replace(/\s/g, '')}`}
                class="text-small text-text-muted hover:text-accent transition-colors whitespace-nowrap focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-cta)] focus-visible:ring-offset-2 rounded-sm"
              >
                {phone}
              </a>
            )}
            {messengerUrl && (
              <a
                href={messengerUrl}
                class="text-small text-text-muted hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-cta)] focus-visible:ring-offset-2 rounded-sm"
                aria-label="Написать в мессенджер"
              >
                Мессенджер ↗
              </a>
            )}
          </div>
        )}
      </div>
      <div class="mt-6 md:mt-0">
        <Button href="#diagnostic" variant="primary">
          Записаться на диагностику
        </Button>
      </div>
    </div>
  </Container>
</footer>
