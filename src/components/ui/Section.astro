---
interface Props {
  class?: string;
  as?: 'section' | 'div';
  /** Светлый, приглушённый или тёмный фон */
  variant?: 'default' | 'subtle' | 'muted' | 'dark';
  /** id для якорных ссылок (например #diagnostic) */
  id?: string;
}
const { class: className = '', as: Tag = 'section', variant = 'default', id } = Astro.props;
const bgClass =
  variant === 'dark'
    ? 'bg-surface-dark'
    : variant === 'muted'
      ? 'bg-surface-muted'
      : variant === 'subtle'
        ? 'bg-surface-subtle'
        : 'bg-surface';
---

<Tag id={id} class:list={['py-section', bgClass, className]}>
  <slot />
</Tag>
