---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
const base =
  'inline-flex items-center rounded-full border border-border bg-surface px-4 py-1.5 text-small text-text hover:border-accent hover:text-accent transition-colors';
---

{href ? (
  <a href={href} class:list={[base, className]}>
    <slot />
  </a>
) : (
  <span class:list={[base, className]}>
    <slot />
  </span>
)}
