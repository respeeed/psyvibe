---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
const base =
  'inline-flex items-center rounded-full border border-white/50 bg-white/45 backdrop-blur-sm px-4 py-1.5 text-small text-text hover:border-accent-brand hover:text-accent-brand transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent-brand)] focus-visible:ring-offset-2';
---

{href ? (
  <a href={href} class:list={[base, className]}>
    <slot />
  </a>
) : (
  <span class:list={[base, className]}>
    <slot />
  </span>
)}
