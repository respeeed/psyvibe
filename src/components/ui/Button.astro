---
interface Props {
  href?: string;
  type?: 'button' | 'submit';
  variant?: 'primary' | 'secondary';
  class?: string;
  disabled?: boolean;
  /** Для кнопки-ссылки: открывать в новой вкладке */
  external?: boolean;
}
const {
  href,
  type = 'button',
  variant = 'primary',
  class: className = '',
  disabled = false,
  external = false,
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-soft px-5 py-2.5 text-body font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none';
const variants = {
  primary:
    'bg-accent text-text-inverse hover:bg-accent-hover',
  secondary:
    'border border-border bg-transparent text-text hover:border-accent hover:text-accent',
};

const classes = [base, variants[variant], className];
const attrs = external && href ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{href ? (
  <a href={href} class:list={classes} {...attrs}>
    <slot />
  </a>
) : (
  <button type={type} class:list={classes} disabled={disabled}>
    <slot />
  </button>
)}
