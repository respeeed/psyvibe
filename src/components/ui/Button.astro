---
interface Props {
  href?: string;
  type?: 'button' | 'submit';
  variant?: 'primary' | 'secondary' | 'tertiary';
  class?: string;
  disabled?: boolean;
  /** Для кнопки-ссылки: открывать в новой вкладке */
  external?: boolean;
}
const {
  href,
  type = 'button',
  variant = 'primary',
  class: className = '',
  disabled = false,
  external = false,
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-lg px-5 py-2.5 text-body font-medium transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-cta)] focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none';
const variants = {
  primary:
    'bg-[var(--color-cta)] text-white hover:bg-[var(--color-cta-hover)] hover:text-white active:bg-[var(--color-cta-active)] active:text-white shadow-sm hover:shadow-md active:shadow-sm',
  secondary:
    'border border-[var(--color-border)] bg-surface text-[var(--color-text)] hover:bg-[var(--color-surface-muted)] hover:border-[var(--color-border-strong)] active:bg-[var(--color-surface-active)]',
  tertiary:
    'bg-[var(--color-primary-100)] text-[var(--color-cta)] hover:bg-[var(--color-primary-200)] hover:text-[var(--color-cta-hover)] active:bg-[var(--color-primary-200)] active:text-[var(--color-cta-active)] border border-transparent',
};

const classes = [base, variants[variant], className];
const attrs = external && href ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{href ? (
  <a href={href} class:list={classes} {...attrs}>
    <slot />
  </a>
) : (
  <button type={type} class:list={classes} disabled={disabled}>
    <slot />
  </button>
)}
