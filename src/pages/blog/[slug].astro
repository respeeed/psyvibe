---
import Layout from '../../components/layout/Layout.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { reader } from '../../lib/keystatic';
import { resolveContentBody, renderMarkdocToHtml } from '../../lib/markdoc';
import { blogImagePath } from '../../lib/images';

export async function getStaticPaths() {
  const slugs = await reader.collections.blog.list();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const siteSettings = await reader.singletons.siteSettings.read();
const seo = await reader.singletons.seo.read();
const post = await reader.collections.blog.read(slug!, { resolveLinkedFiles: true });
if (!post) {
  return Astro.redirect('/404');
}

const imageSrc = blogImagePath(slug ?? null, post.image);
const bodyContent = await resolveContentBody(post.body);
const bodyHtml = renderMarkdocToHtml(bodyContent ?? null);
const metaDesc = (post.excerpt ?? post.title ?? 'Статья блога').replace(/\s+/g, ' ').trim().slice(0, 155);
const canonicalUrl = Astro.canonicalURL?.href ?? null;
const postTitleStr = typeof post.title === 'string' ? post.title : (post.title && typeof post.title === 'object' && 'name' in post.title ? (post.title as { name?: string }).name : null) ?? slug ?? 'Статья';
const pageTitle = (post as { seoTitle?: string | null })?.seoTitle?.trim() || postTitleStr;
---

<Layout title={pageTitle} siteSettings={siteSettings} seo={seo} description={metaDesc} canonicalUrl={canonicalUrl}>
  <Section>
    <Container>
      <nav class="mx-auto max-w-3xl mb-6" aria-label="Навигация">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-body text-text-muted hover:text-[var(--color-accent-brand)] transition-colors">
          <span aria-hidden="true">←</span>
          Вернуться назад
        </a>
      </nav>
      <article class="mx-auto max-w-3xl">
        <header class="mb-8">
          <h1 class="text-h1 text-heading">
            {post.title}
          </h1>
          {post.publishDate && (
            <time
              class="mt-2 block text-body text-text-muted"
              datetime={post.publishDate}
            >
              {new Date(post.publishDate).toLocaleDateString('ru-RU', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })}
            </time>
          )}
          {post.excerpt && (
            <p class="mt-4 text-body text-text-muted">
              {post.excerpt}
            </p>
          )}
        </header>

        {imageSrc && (
          <figure class="mb-8 overflow-hidden rounded-soft">
            <img
              src={imageSrc}
              alt=""
              width="800"
              height="450"
              class="aspect-video w-full object-cover"
            />
          </figure>
        )}

        {bodyHtml ? (
          <div
            class="prose-content text-body text-text"
            set:html={bodyHtml}
          />
        ) : null}
      </article>
    </Container>
  </Section>
</Layout>
