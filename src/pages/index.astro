---
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/home/Hero.astro';
import WhyTrust from '../components/home/WhyTrust.astro';
import Process from '../components/home/Process.astro';
import Benefits from '../components/home/Benefits.astro';
import CtaBlock from '../components/home/CtaBlock.astro';
import DiscussBlock from '../components/home/DiscussBlock.astro';
import Diagnostic from '../components/home/Diagnostic.astro';
import RelevantFor from '../components/home/RelevantFor.astro';
import Format from '../components/home/Format.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import Results from '../components/home/Results.astro';
import Faq from '../components/home/Faq.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import { reader } from '../lib/keystatic';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const BLOG_DIR = path.join(__dirname, '../content/blog');

function getBlogPostsFromFilesystem(): { slug: string; title?: string; excerpt?: string; publishDate?: string; image?: string }[] {
  if (!fs.existsSync(BLOG_DIR)) return [];
  const files = fs.readdirSync(BLOG_DIR).filter((f) => f.endsWith('.mdoc'));
  const posts: { slug: string; title?: string; excerpt?: string; publishDate?: string; image?: string }[] = [];
  for (const file of files) {
    const slug = file.replace(/\.mdoc$/, '');
    const raw = fs.readFileSync(path.join(BLOG_DIR, file), 'utf-8');
    const parts = raw.split(/\n---\n/);
    const front = parts[1];
    if (!front) continue;
    const meta: Record<string, string> = {};
    for (const line of front.split('\n')) {
      const m = line.match(/^(\w+):\s*(.*)$/);
      if (m) meta[m[1]] = m[2].trim();
    }
    posts.push({ slug, title: meta.title, excerpt: meta.excerpt, publishDate: meta.publishDate, image: meta.image });
  }
  return posts;
}

const siteSettings = await reader.singletons.siteSettings.read();
const home = await reader.singletons.home.read();

let blogSlugs = await reader.collections.blog.list();
let rawBlogPosts = await Promise.all(
  blogSlugs.map(async (slug) => {
    const entry = await reader.collections.blog.read(slug);
    return entry ? { slug, ...entry } : null;
  })
);
let blogPosts = rawBlogPosts.filter((p): p is NonNullable<typeof p> => p != null);
if (blogPosts.length === 0) {
  blogPosts = getBlogPostsFromFilesystem();
}
blogPosts.sort((a, b) => {
  const d1 = a?.publishDate ? new Date(a.publishDate).getTime() : 0;
  const d2 = b?.publishDate ? new Date(b.publishDate).getTime() : 0;
  return d2 - d1;
});

const metaDesc = (home?.hero?.subtitle ?? 'Сайт психолога Елизаветы Шихалевой').replace(/\s+/g, ' ').trim().slice(0, 155);
const canonicalUrl = Astro.canonicalURL?.href ?? null;
---

<Layout title="Главная" siteSettings={siteSettings} description={metaDesc} canonicalUrl={canonicalUrl}>
  <Hero hero={home?.hero ?? null} />
  <WhyTrust data={home?.whyTrust ?? null} />
  <Process data={home?.process ?? null} />
  <Benefits data={home?.benefits ?? null} />
  <CtaBlock data={home?.cta ?? null} />
  <Diagnostic data={home?.diagnostic ?? null} />
  <Format data={home?.format ?? null} />
  <HowItWorks data={home?.howItWorks ?? null} />
  <DiscussBlock data={home?.discuss ?? null} siteSettings={siteSettings} />
  <Results data={home?.results ?? null} />
  <RelevantFor data={home?.relevantFor ?? null} />
  <Faq data={home?.faq ?? null} />
  <BlogPreview sectionData={home?.blogPreview ?? null} posts={blogPosts} />
</Layout>
